@model AppointmentFormViewModel

@{
    ViewData["Title"] = "Edit Appointment";
}

<div class="page-header">
    <div>
        <div class="page-kicker">Schedule</div>
        <h1>Edit Appointment</h1>
        <p class="page-subtitle">Update date, time, service type, status, and visit notes.</p>
    </div>
</div>

<form asp-action="Edit" method="post">
    <input asp-for="AppointmentId" type="hidden" />
    <partial name="_Form" model="Model" />
    <div class="mt-4 d-flex gap-2">
        <button type="submit" class="btn btn-primary">Save Changes</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
