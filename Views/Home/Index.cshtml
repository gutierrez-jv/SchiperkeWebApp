@{
    ViewData["Title"] = "Home";
}

<section class="home-hero">
    <div class="home-hero-copy">
        <div class="eyebrow">Appointments, patient records, and preventive care</div>
        <h1>Patient-Centered Veterinary Care Without Personal Data Exposure</h1>
        <p>Book appointments quickly while authorized clinic staff manage pet records, consultations, vaccinations, and wellness care in a secure workspace.</p>
        <div class="hero-actions">
            <a asp-controller="Appointments" asp-action="Book" class="btn btn-primary btn-lg">Schedule Your Visit</a>
            <a asp-controller="Home" asp-action="Contact" class="btn btn-outline-primary btn-lg">Contact Clinic</a>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <a asp-controller="Dashboard" asp-action="Index" class="btn btn-outline-primary btn-lg">Open Dashboard</a>
            }
            else
            {
                <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary btn-lg">Staff Login</a>
            }
        </div>
    </div>
    <div class="home-hero-visual">
        <img src="~/images/clinic-hero.svg" alt="Veterinary clinic care scene" />
    </div>
</section>

<section class="home-dashboard">
    <div class="dashboard-column quick-actions-column">
        <div class="section-heading">
            <h2>Quick Actions</h2>
        </div>
        <div class="quick-action-grid">
            <a asp-controller="Appointments" asp-action="Book" class="action-card action-card-primary">
                <span class="action-icon">01</span>
                <strong>Book an Appointment</strong>
                <span>Select date, time, and service.</span>
                <span class="action-link">Schedule Now</span>
            </a>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <a asp-controller="Pets" asp-action="Index" class="action-card">
                    <span class="action-icon">02</span>
                    <strong>Patient Records</strong>
                    <span>View signalment, visits, and medical records.</span>
                    <span class="action-link">Access Records</span>
                </a>
            }
            else
            {
                <a asp-controller="Account" asp-action="Login" class="action-card">
                    <span class="action-icon">02</span>
                    <strong>Staff Portal</strong>
                    <span>Secure access for clinic admin and staff.</span>
                    <span class="action-link">Sign In</span>
                </a>
            }
            <a asp-controller="Home" asp-action="Contact" class="action-card">
                <span class="action-icon">03</span>
                <strong>Contact Page</strong>
                <span>Find clinic contact details and booking reminders.</span>
                <span class="action-link">View Contact</span>
            </a>
        </div>
    </div>

    <div class="dashboard-column">
        <div class="section-heading">
            <h2>Clinic Workflow</h2>
        </div>
        <div class="appointment-preview">
            <div class="preview-date">
                <span>Today</span>
                <strong>Open</strong>
            </div>
            <div>
                <strong>Appointment requests are public.</strong>
                <span>Requests only need the patient number, visit date, service type, and reason for visit.</span>
            </div>
        </div>
        <div class="appointment-preview">
            <div class="preview-date">
                <span>Staff</span>
                <strong>Only</strong>
            </div>
            <div>
                <strong>Records stay protected.</strong>
                <span>Pet records, consultations, vaccinations, wellness, and users require staff login.</span>
            </div>
        </div>
    </div>

    <div class="dashboard-column">
        <div class="section-heading">
            <h2>Featured Services</h2>
        </div>
        <div class="service-grid">
            <a asp-controller="Appointments" asp-action="Book" class="service-card">
                <strong>Wellness Exams</strong>
                <span>Routine wellness and preventive visits.</span>
            </a>
            <a asp-controller="Appointments" asp-action="Book" class="service-card">
                <strong>Vaccinations</strong>
                <span>Vaccination appointments and due-date tracking.</span>
            </a>
            <a asp-controller="Appointments" asp-action="Book" class="service-card">
                <strong>Consultations</strong>
                <span>Chief complaint, exam, assessment, and treatment.</span>
            </a>
            <a asp-controller="Appointments" asp-action="Book" class="service-card">
                <strong>Wellness Care</strong>
                <span>Deworming and antiparasitic medication records.</span>
            </a>
        </div>
    </div>
</section>

<section class="requirement-strip">
    <div>
        <strong>Appointment System</strong>
        <span>Public booking for visit requests.</span>
    </div>
    <div>
        <strong>Pet Records</strong>
        <span>Patient number, signalment, and medical history.</span>
    </div>
    <div>
        <strong>Vaccination Records</strong>
        <span>Due dates, overdue tracking, and wellness reminders.</span>
    </div>
    <div>
        <strong>Contact Page</strong>
        <span>Clinic contact details without private data storage.</span>
    </div>
</section>

@if (User.Identity?.IsAuthenticated == true)
{
    <section class="content-panel staff-module-panel">
        <div class="page-header">
            <div>
                <div class="page-kicker">Staff Workspace</div>
                <h2 class="h3 mb-0">Clinic Modules</h2>
                <p class="page-subtitle">Open the records used for daily clinic work.</p>
            </div>
        </div>

        <div class="module-grid">
            <a asp-controller="Pets" asp-action="Index" class="module-card">
                <strong>Patients</strong>
                <span>Patient registration and signalment.</span>
            </a>
            <a asp-controller="Appointments" asp-action="Index" class="module-card">
                <strong>Appointments</strong>
                <span>Daily schedule and appointment status.</span>
            </a>
            <a asp-controller="ConsultationRecords" asp-action="Index" class="module-card">
                <strong>Consultations</strong>
                <span>Chief complaint, history, vitals, assessment, and treatment.</span>
            </a>
            <a asp-controller="VaccinationRecords" asp-action="Index" class="module-card">
                <strong>Vaccinations</strong>
                <span>Vaccine records, dose details, and due dates.</span>
            </a>
            <a asp-controller="WellnessRecords" asp-action="Index" class="module-card">
                <strong>Wellness</strong>
                <span>Deworming and preventive care records.</span>
            </a>
            <a asp-controller="Users" asp-action="Index" class="module-card">
                <strong>Users</strong>
                <span>Admin and staff accounts.</span>
            </a>
        </div>
    </section>
}
