@model WellnessRecordFormViewModel

@{
    var selectedAppointment = Model.AppointmentOptions.FirstOrDefault(option => option.Selected)?.Text;
    var selectedPatient = Model.PetOptions.FirstOrDefault(option => option.Selected)?.Text;
    var isLinkedToAppointment = Model.AppointmentId.HasValue;
}

<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

<div class="row g-3">
    @if (isLinkedToAppointment)
    {
        <input asp-for="PetId" type="hidden" />
        <input asp-for="AppointmentId" type="hidden" />
        <div class="col-12">
            <div class="locked-context-card">
                <span>Completed appointment</span>
                <strong>@(selectedAppointment ?? $"Appointment #{Model.AppointmentId}")</strong>
                <small>Patient: @(selectedPatient ?? "Selected patient"). The linked appointment and patient are locked to avoid mismatched records.</small>
            </div>
        </div>
    }
    else
    {
        <div class="col-md-6">
            <label asp-for="PetId" class="form-label"></label>
            <select asp-for="PetId" asp-items="Model.PetOptions" class="form-select">
                <option value="">Select pet</option>
            </select>
            <span asp-validation-for="PetId" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="AppointmentId" class="form-label"></label>
            <select asp-for="AppointmentId" asp-items="Model.AppointmentOptions" class="form-select">
                <option value="">No linked appointment</option>
            </select>
            <span asp-validation-for="AppointmentId" class="text-danger"></span>
            <span class="form-hint">Only completed deworming, antiparasitic, and wellness appointments are shown.</span>
        </div>
    }
    <div class="col-md-6">
        <label asp-for="RecordedByUserId" class="form-label"></label>
        <select asp-for="RecordedByUserId" asp-items="Model.UserOptions" class="form-select">
            <option value="">Select user</option>
        </select>
        <span asp-validation-for="RecordedByUserId" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="WellnessType" class="form-label"></label>
        <select asp-for="WellnessType" asp-items="Model.WellnessTypeOptions" class="form-select">
            <option value="">Select wellness type</option>
        </select>
        <span asp-validation-for="WellnessType" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="ProductOrMedication" class="form-label"></label>
        <input asp-for="ProductOrMedication" class="form-control" />
        <span asp-validation-for="ProductOrMedication" class="text-danger"></span>
    </div>
    <div class="col-md-3">
        <label asp-for="DateGiven" class="form-label"></label>
        <input asp-for="DateGiven" type="date" class="form-control" />
        <span asp-validation-for="DateGiven" class="text-danger"></span>
    </div>
    <div class="col-md-3">
        <label asp-for="NextDueDate" class="form-label"></label>
        <input asp-for="NextDueDate" type="date" class="form-control" />
        <span asp-validation-for="NextDueDate" class="text-danger"></span>
    </div>
    <div class="col-md-3">
        <label asp-for="Dose" class="form-label"></label>
        <input asp-for="Dose" class="form-control" />
        <span asp-validation-for="Dose" class="text-danger"></span>
    </div>
    <div class="col-md-3">
        <label asp-for="Route" class="form-label"></label>
        <input asp-for="Route" class="form-control" />
        <span asp-validation-for="Route" class="text-danger"></span>
    </div>
    <div class="col-12">
        <label asp-for="Remarks" class="form-label"></label>
        <textarea asp-for="Remarks" class="form-control" rows="4"></textarea>
        <span asp-validation-for="Remarks" class="text-danger"></span>
    </div>
</div>
