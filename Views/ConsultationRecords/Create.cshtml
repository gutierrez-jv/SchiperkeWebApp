@model ConsultationRecordFormViewModel

@{
    ViewData["Title"] = "Create Consultation Record";
}

<div class="page-header">
    <div>
        <div class="page-kicker">Health Services</div>
        <h1>Create Consultation Record</h1>
        <p class="page-subtitle">Record the clinical visit after a completed consultation appointment.</p>
    </div>
</div>

<form asp-action="Create" method="post">
    <partial name="_Form" model="Model" />
    <div class="mt-4 form-actions">
        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
