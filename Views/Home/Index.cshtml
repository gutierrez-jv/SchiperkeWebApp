@{
    ViewData["Title"] = "Home";
}

<section class="home-hero">
    <div class="home-hero-copy">
        <div class="eyebrow">PAWS: Schipperke Web App</div>
        <h1>Compassionate Care for Every Pet Patient</h1>
        <p>Book a clinic visit with Schipperke Animal Clinic and Veterinary Supplies, then keep your appointment code for status updates.</p>
        <div class="hero-actions">
            <a asp-controller="Appointments" asp-action="Book" class="btn btn-primary btn-lg">Schedule Your Visit</a>
            <a asp-controller="Appointments" asp-action="Book" asp-route-track="true" class="btn btn-outline-primary btn-lg">Check Status</a>
            <a asp-controller="Home" asp-action="Contact" class="btn btn-outline-primary btn-lg">Contact Clinic</a>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <a asp-controller="Dashboard" asp-action="Index" class="btn btn-outline-primary btn-lg">Open Dashboard</a>
            }
            else
            {
                <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary btn-lg">Login</a>
            }
        </div>
    </div>
    <div class="home-hero-visual">
        <img class="home-hero-photo" src="~/images/frontpage-hero.png" alt="Dog and cat welcoming clinic visitors" />
    </div>
</section>

@if (User.Identity?.IsAuthenticated == true)
{
    <section class="content-panel staff-module-panel">
        <div class="page-header">
            <div>
                <div class="page-kicker">Staff Workspace</div>
                <h2 class="h3 mb-0">PAWS Modules</h2>
                <p class="page-subtitle">Daily clinic workspace.</p>
            </div>
        </div>

        <div class="module-grid">
            <a asp-controller="Pets" asp-action="Index" class="module-card">
                <strong>Patients</strong>
                <span>Patient registration and signalment.</span>
            </a>
            <a asp-controller="Appointments" asp-action="Index" class="module-card">
                <strong>Appointments</strong>
                <span>Daily schedule and appointment status.</span>
            </a>
            <a asp-controller="ConsultationRecords" asp-action="Index" class="module-card">
                <strong>Consultations</strong>
                <span>Chief complaint, history, vitals, assessment, and treatment.</span>
            </a>
            <a asp-controller="VaccinationRecords" asp-action="Index" class="module-card">
                <strong>Vaccinations</strong>
                <span>Vaccine records, dose details, and due dates.</span>
            </a>
            <a asp-controller="WellnessRecords" asp-action="Index" class="module-card">
                <strong>Wellness</strong>
                <span>Deworming and preventive care records.</span>
            </a>
            @if (User.IsInRole("Admin"))
            {
                <a asp-controller="Users" asp-action="Index" class="module-card">
                    <strong>Users</strong>
                    <span>Clinic accounts.</span>
                </a>
            }
        </div>
    </section>
}
else
{
    <section class="public-home-grid" aria-label="Clinic visit information">
        <article class="public-home-card public-home-card-featured">
            <span class="page-kicker">Clinic Information</span>
            <h2>Schipperke Animal Clinic and Veterinary Supplies</h2>
            <div class="home-clinic-list">
                <span><strong>Location</strong> 5HCQ+MCJ, MacArthur Hwy, Angeles, Pampanga</span>
                <span><strong>Phone</strong> (045) 331 4807</span>
                <span><strong>Reminder</strong> Call before visiting if you need to confirm clinic hours.</span>
            </div>
        </article>

        <article class="public-home-card">
            <span class="page-kicker">Booking Flow</span>
            <h2>Request first, then check status</h2>
            <p>Submit the pet visit details online. The clinic reviews the request and updates it as pending, confirmed, cancelled, completed, or no-show.</p>
        </article>

        <article class="public-home-card">
            <span class="page-kicker">Privacy First</span>
            <h2>Pet-centered records only</h2>
            <p>PAWS tracks pet patient details, appointment codes, and clinic records without storing owner or client contact information.</p>
        </article>
    </section>
}
