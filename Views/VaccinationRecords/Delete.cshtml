@model VaccinationRecord

@{
    ViewData["Title"] = "Delete Vaccination Record";
}

<h1>Delete Vaccination Record</h1>
<div class="soft-delete-note">
    Are you sure you want to delete this vaccination record? This record will not be permanently removed and will only be hidden from normal lists.
</div>

<dl class="row">
    <dt class="col-sm-3">Pet</dt>
    <dd class="col-sm-9">@Model.Pet.PatientNo - @Model.Pet.PetName</dd>
    <dt class="col-sm-3">Vaccine Name</dt>
    <dd class="col-sm-9">@Model.VaccineName</dd>
    <dt class="col-sm-3">Date Given</dt>
    <dd class="col-sm-9">@Model.DateGiven.ToString("yyyy-MM-dd")</dd>
</dl>

<form asp-action="Delete" method="post" data-paws-confirm="Delete this vaccination record? It will be hidden from normal lists but kept in the database.">
    <input type="hidden" asp-for="VaccinationId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
</form>
