@model WellnessRecordFormViewModel

@{
    ViewData["Title"] = "Edit Wellness Record";
}

<div class="page-header">
    <div>
        <div class="page-kicker">Wellness Services</div>
        <h1>Edit Wellness Record</h1>
        <p class="page-subtitle">Update wellness treatment details and next due dates.</p>
    </div>
</div>

<form asp-action="Edit" method="post">
    <input asp-for="WellnessId" type="hidden" />
    <partial name="_Form" model="Model" />
    <div class="mt-4 form-actions">
        <button type="submit" class="btn btn-primary">Save Changes</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
