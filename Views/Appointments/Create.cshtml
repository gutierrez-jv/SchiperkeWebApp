@model AppointmentFormViewModel

@{
    ViewData["Title"] = "Create Appointment";
}

<div class="page-header">
    <div>
        <div class="page-kicker">Schedule</div>
        <h1>Create Appointment</h1>
        <p class="page-subtitle">Schedule a pet visit without storing client or owner information.</p>
    </div>
</div>

<form asp-action="Create" method="post">
    <partial name="_Form" model="Model" />
    <div class="mt-4 form-actions">
        <button type="submit" class="btn btn-primary">Save Appointment</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
