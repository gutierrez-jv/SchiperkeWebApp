@{
    ViewData["Title"] = "Contact";
}

<section class="contact-hero">
    <div>
        <div class="page-kicker">PAWS Contact</div>
        <h1>Reach the clinic without exposing private personal information.</h1>
        <p>
            Use the PAWS appointment form for visit requests. Staff can use the secured workspace
            to manage pet records, appointments, consultations, vaccinations, and wellness care.
        </p>
        <div class="hero-actions">
            <a asp-controller="Appointments" asp-action="Book" class="btn btn-primary btn-lg">Book Appointment</a>
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary btn-lg">Back Home</a>
        </div>
    </div>
    <aside class="contact-privacy-card">
        <strong>Privacy Limitation</strong>
        <span>This system is pet or patient centered only. Do not enter names, addresses, or personal contact details into clinic records.</span>
    </aside>
</section>

<section class="contact-grid">
    <article class="contact-card">
        <span class="contact-icon">01</span>
        <h2>Appointment Desk</h2>
        <p>For booking requests, use the public appointment page and provide the pet patient number.</p>
        <a asp-controller="Appointments" asp-action="Book">Open booking form</a>
    </article>

    <article class="contact-card">
        <span class="contact-icon">02</span>
        <h2>Viber</h2>
        <p>Primary appointment contact number.</p>
        <strong>0999-739-4215</strong>
    </article>

    <article class="contact-card">
        <span class="contact-icon">03</span>
        <h2>Clinic Records</h2>
        <p>Pet records, vaccination records, wellness records, and consultations are available to authorized staff only.</p>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <a asp-controller="Dashboard" asp-action="Index">Open staff dashboard</a>
        }
        else
        {
            <a asp-controller="Account" asp-action="Login">Staff login</a>
        }
    </article>
</section>

<section class="content-panel contact-note-panel">
    <div class="section-heading">
        <h2>What to prepare before booking</h2>
    </div>
    <div class="contact-checklist">
        <span>Pet patient number</span>
        <span>Preferred appointment date and time</span>
        <span>Service type such as consultation, vaccination, deworming, or wellness care</span>
        <span>Short reason for visit or concern</span>
    </div>
</section>
