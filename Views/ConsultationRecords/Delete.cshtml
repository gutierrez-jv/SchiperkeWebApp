@model ConsultationRecord

@{
    ViewData["Title"] = "Deactivate Consultation Record";
}

<h1>Deactivate Consultation Record</h1>
<div class="soft-delete-note">
    Are you sure you want to deactivate this consultation record? This record will not be permanently deleted and will only be hidden from normal lists.
</div>

<dl class="row">
    <dt class="col-sm-3">Pet</dt>
    <dd class="col-sm-9">@Model.Pet.PatientNo - @Model.Pet.PetName</dd>
    <dt class="col-sm-3">Consultation Date</dt>
    <dd class="col-sm-9">@Model.ConsultationDate.ToString("yyyy-MM-dd HH:mm")</dd>
    <dt class="col-sm-3">Chief Complaint</dt>
    <dd class="col-sm-9">@Model.ChiefComplaint</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="ConsultationId" />
    <button type="submit" class="btn btn-danger">Deactivate</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
</form>
