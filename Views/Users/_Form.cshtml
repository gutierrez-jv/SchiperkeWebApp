@model UserFormViewModel

@{
    var passwordPlaceholder = Model.UserId == 0
        ? "Enter password"
        : "Leave blank to keep current password";
}

<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

<div class="row g-3">
    <div class="col-md-6">
        <label asp-for="Username" class="form-label"></label>
        <input asp-for="Username" class="form-control" />
        <span asp-validation-for="Username" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="FullName" class="form-label"></label>
        <input asp-for="FullName" class="form-control" />
        <span asp-validation-for="FullName" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="Role" class="form-label"></label>
        <select asp-for="Role" class="form-select">
            <option value="">Select role</option>
            <option value="Admin">Admin</option>
            <option value="Staff">Staff</option>
            <option value="Veterinarian">Veterinarian</option>
        </select>
        <span asp-validation-for="Role" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="PasswordHash" class="form-label"></label>
        <input asp-for="PasswordHash" class="form-control" autocomplete="new-password" placeholder="@passwordPlaceholder" />
        @if (Model.UserId != 0)
        {
            <span class="form-hint">Leave this blank unless you want to change the password.</span>
        }
        <span asp-validation-for="PasswordHash" class="text-danger"></span>
    </div>
</div>
