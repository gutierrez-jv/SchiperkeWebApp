@{
    ViewData["Title"] = "Contact";
}

<section class="contact-hero">
    <div>
        <div class="page-kicker">PAWS Contact</div>
        <h1>Plan a visit with Schipperke Animal Clinic.</h1>
        <p>
            Use the booking page for appointment requests, then keep your appointment code for follow-up.
            Clinic staff will review requests and update the appointment status.
        </p>
        <div class="hero-actions">
            <a asp-controller="Appointments" asp-action="Book" class="btn btn-primary btn-lg">Book Appointment</a>
            <a asp-controller="Appointments" asp-action="Book" asp-route-track="true" class="btn btn-outline-primary btn-lg">Check Status</a>
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary btn-lg">Back Home</a>
        </div>
    </div>
    <aside class="contact-privacy-card">
        <strong>Schipperke Animal Clinic and Veterinary Supplies</strong>
        <span>5HCQ+MCJ, MacArthur Hwy, Angeles, Pampanga</span>
    </aside>
</section>

<section class="contact-grid">
    <article class="contact-card">
        <span class="contact-icon">01</span>
        <h2>Appointment Desk</h2>
        <p>Book a consultation, vaccination, deworming, antiparasitic treatment, or wellness visit.</p>
        <a asp-controller="Appointments" asp-action="Book">Open booking form</a>
    </article>

    <article class="contact-card">
        <span class="contact-icon">02</span>
        <h2>Clinic Phone</h2>
        <p>Use this number for clinic follow-up when needed.</p>
        <strong>(045) 331 4807</strong>
    </article>

    <article class="contact-card">
        <span class="contact-icon">03</span>
        <h2>Appointment Tracking</h2>
        <p>Check whether a booking is pending, confirmed, completed, cancelled, or marked no-show.</p>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <a asp-controller="Appointments" asp-action="Index">Open appointments</a>
        }
        else
        {
            <a asp-controller="Appointments" asp-action="Book" asp-route-track="true">Check status</a>
        }
    </article>
</section>

<section class="content-panel contact-note-panel">
    <div class="section-heading">
        <h2>What to prepare before booking</h2>
    </div>
    <div class="contact-checklist">
        <span>Pet patient number</span>
        <span>Preferred appointment date and time</span>
        <span>Service type such as consultation, vaccination, deworming, or wellness care</span>
        <span>Short reason for visit or concern</span>
    </div>
</section>
