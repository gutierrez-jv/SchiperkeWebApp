@model Pet

@{
    ViewData["Title"] = "Deactivate Pet";
}

<h1>Deactivate Pet</h1>
<div class="soft-delete-note">
    Are you sure you want to deactivate this patient record? This record will not be permanently deleted and can still be recovered if needed.
</div>

<dl class="row">
    <dt class="col-sm-3">Patient No.</dt>
    <dd class="col-sm-9">@Model.PatientNo</dd>
    <dt class="col-sm-3">Pet Name</dt>
    <dd class="col-sm-9">@Model.PetName</dd>
    <dt class="col-sm-3">Species</dt>
    <dd class="col-sm-9">@Model.Species</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="PetId" />
    <button type="submit" class="btn btn-danger">Deactivate</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
</form>
