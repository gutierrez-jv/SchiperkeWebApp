@model VaccinationRecordFormViewModel

@{
    ViewData["Title"] = "Edit Vaccination Record";
}

<div class="page-header">
    <div>
        <div class="page-kicker">Preventive Care</div>
        <h1>Edit Vaccination Record</h1>
        <p class="page-subtitle">Keep vaccine and due-date information accurate for patient follow-up.</p>
    </div>
</div>

<form asp-action="Edit" method="post">
    <input asp-for="VaccinationId" type="hidden" />
    <partial name="_Form" model="Model" />
    <div class="mt-4 form-actions">
        <button type="submit" class="btn btn-primary">Save Changes</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
