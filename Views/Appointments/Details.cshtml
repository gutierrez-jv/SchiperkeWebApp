@model Appointment

@{
    ViewData["Title"] = "Appointment Details";
    var appointmentCode = Model.AppointmentCode ?? $"APT-{Model.AppointmentId:0000}";
    var patientNo = Model.PatientNoInput ?? Model.Pet?.PatientNo ?? "New patient";
    var petName = Model.PetName ?? Model.Pet?.PetName ?? "Unnamed pet";
    var species = Model.Species ?? Model.Pet?.Species;
    var breed = Model.Breed ?? Model.Pet?.Breed;
    var sex = Model.Sex ?? Model.Pet?.Sex;
    var color = Model.Color ?? Model.Pet?.Color;
    var canRegisterPatient = Model.PetId is null
        && (Model.Status.Equals("Confirmed", StringComparison.OrdinalIgnoreCase)
            || Model.Status.Equals("Completed", StringComparison.OrdinalIgnoreCase))
        && !string.IsNullOrWhiteSpace(Model.PetName)
        && !string.IsNullOrWhiteSpace(Model.Species)
        && !string.IsNullOrWhiteSpace(Model.Sex);
    var canCreateMedicalRecord = Model.PetId.HasValue
        && Model.Status.Equals("Completed", StringComparison.OrdinalIgnoreCase);
    var isConsultation = Model.ServiceType.Equals("Consultation", StringComparison.OrdinalIgnoreCase);
    var isVaccination = Model.ServiceType.Equals("Vaccination", StringComparison.OrdinalIgnoreCase);
    var isWellness = Model.ServiceType.Equals("Deworming", StringComparison.OrdinalIgnoreCase)
        || Model.ServiceType.Equals("Internal Antiparasitic", StringComparison.OrdinalIgnoreCase)
        || Model.ServiceType.Equals("External Antiparasitic", StringComparison.OrdinalIgnoreCase)
        || Model.ServiceType.Equals("General Wellness", StringComparison.OrdinalIgnoreCase);
}

<div class="page-header">
    <div>
        <div class="page-kicker">Schedule</div>
        <h1>Appointment Details</h1>
        <p class="page-subtitle">Client-facing booking details centered on the pet patient.</p>
    </div>
</div>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success" role="alert">@successMessage</div>
}

@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger" role="alert">@errorMessage</div>
}

<dl class="row">
    <dt class="col-sm-3">Appointment Code</dt>
    <dd class="col-sm-9">@appointmentCode</dd>

    <dt class="col-sm-3">Existing Patient</dt>
    <dd class="col-sm-9">@(Model.IsExistingPatient ? "Yes" : "No")</dd>

    <dt class="col-sm-3">Patient No</dt>
    <dd class="col-sm-9">@patientNo</dd>

    <dt class="col-sm-3">Pet Name</dt>
    <dd class="col-sm-9">@petName</dd>

    <dt class="col-sm-3">Species</dt>
    <dd class="col-sm-9">@species</dd>

    <dt class="col-sm-3">Breed</dt>
    <dd class="col-sm-9">@breed</dd>

    <dt class="col-sm-3">Sex</dt>
    <dd class="col-sm-9">@sex</dd>

    <dt class="col-sm-3">Color</dt>
    <dd class="col-sm-9">@color</dd>

    <dt class="col-sm-3">Appointment Date</dt>
    <dd class="col-sm-9">@Model.AppointmentDate.ToString("yyyy-MM-dd")</dd>

    <dt class="col-sm-3">Appointment Time</dt>
    <dd class="col-sm-9">@Model.AppointmentTime.ToString("hh:mm tt")</dd>

    <dt class="col-sm-3">Service Type</dt>
    <dd class="col-sm-9">@Model.ServiceType</dd>

    <dt class="col-sm-3">Reason for Visit</dt>
    <dd class="col-sm-9">@Model.ReasonForVisit</dd>

    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">@Model.Status</dd>

    <dt class="col-sm-3">Remarks</dt>
    <dd class="col-sm-9">@Model.Remarks</dd>

    @if (Model.Status.Equals("Cancelled", StringComparison.OrdinalIgnoreCase)
        || !string.IsNullOrWhiteSpace(Model.CancellationReason)
        || !string.IsNullOrWhiteSpace(Model.CancelledBy)
        || Model.CancelledAt.HasValue)
    {
        <dt class="col-sm-3">Cancellation Reason</dt>
        <dd class="col-sm-9">@(Model.CancellationReason ?? "No reason provided.")</dd>

        <dt class="col-sm-3">Cancelled By</dt>
        <dd class="col-sm-9">@(Model.CancelledBy ?? "Not recorded")</dd>

        <dt class="col-sm-3">Cancelled At</dt>
        <dd class="col-sm-9">@(Model.CancelledAt?.ToString("yyyy-MM-dd HH:mm") ?? "Not recorded")</dd>
    }

    <dt class="col-sm-3">Created By</dt>
    <dd class="col-sm-9">@(Model.CreatedByUser?.FullName ?? "Public booking")</dd>

    <dt class="col-sm-3">Created At</dt>
    <dd class="col-sm-9">@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</dd>

    <dt class="col-sm-3">Updated At</dt>
    <dd class="col-sm-9">@Model.UpdatedAt?.ToString("yyyy-MM-dd HH:mm")</dd>
</dl>

<div class="d-flex gap-2">
    @if (canRegisterPatient)
    {
        <form asp-action="RegisterPatient" asp-route-id="@Model.AppointmentId" method="post">
            <button type="submit" class="btn btn-success">Register Patient</button>
        </form>
    }
    @if (canCreateMedicalRecord && isConsultation)
    {
        <a asp-controller="ConsultationRecords" asp-action="Create" asp-route-appointmentId="@Model.AppointmentId" class="btn btn-success">Create Consultation Record</a>
    }
    @if (canCreateMedicalRecord && isVaccination)
    {
        <a asp-controller="VaccinationRecords" asp-action="Create" asp-route-appointmentId="@Model.AppointmentId" class="btn btn-success">Create Vaccination Record</a>
    }
    @if (canCreateMedicalRecord && isWellness)
    {
        <a asp-controller="WellnessRecords" asp-action="Create" asp-route-appointmentId="@Model.AppointmentId" class="btn btn-success">Create Wellness Record</a>
    }
    <a asp-action="Edit" asp-route-id="@Model.AppointmentId" class="btn btn-primary">Edit</a>
    <a asp-action="Delete" asp-route-id="@Model.AppointmentId" class="btn btn-outline-danger">Delete</a>
    <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
</div>
