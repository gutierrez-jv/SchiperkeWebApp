@model IEnumerable<VaccinationRecord>

@{
    ViewData["Title"] = "Vaccination Records";
    var dueFilter = ViewData["DueFilter"]?.ToString();
}

<div class="page-header">
    <div>
        <div class="page-kicker">Wellness Services</div>
        <h1>Vaccination Records</h1>
        <p class="page-subtitle">Track vaccines, date given, next due date, and recorded user.</p>
    </div>
    <div class="page-actions">
        <a asp-action="Create" class="btn btn-primary">Add Record</a>
    </div>
</div>

<form method="get" class="search-panel">
    <div class="row g-2 align-items-end">
        <div class="col-md-4">
            <label class="form-label" for="petId">Patient</label>
            <select id="petId" name="petId" asp-items="@(ViewData["PetOptions"] as IEnumerable<SelectListItem>)" class="form-select">
                <option value="">All patients</option>
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label" for="dueFilter">Due Date</label>
            <select id="dueFilter" name="dueFilter" class="form-select">
                <option value="">All records</option>
                <option value="upcoming" selected="@(dueFilter == "upcoming" ? "selected" : null)">Due within 30 days</option>
                <option value="overdue" selected="@(dueFilter == "overdue" ? "selected" : null)">Overdue</option>
            </select>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-outline-primary w-100">Filter</button>
        </div>
        <div class="col-md-2">
            <a asp-action="Index" class="btn btn-outline-secondary w-100">Clear</a>
        </div>
    </div>
</form>

<div class="table-shell">
    <div class="table-responsive">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Pet</th>
                    <th>Vaccine</th>
                    <th>Date Given</th>
                    <th>Next Due</th>
                    <th>Recorded By</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="6" class="empty-state">No vaccination records found.</td>
                </tr>
            }
            else
            {
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@(item.Pet?.PatientNo ?? "No patient no") - @(item.Pet?.PetName ?? "Unknown pet")</td>
                        <td><strong>@item.VaccineName</strong></td>
                        <td>@item.DateGiven.ToString("yyyy-MM-dd")</td>
                        <td>@(item.NextDueDate?.ToString("yyyy-MM-dd") ?? "Not set")</td>
                        <td>@(item.RecordedByUser?.FullName ?? "Not recorded")</td>
                        <td class="text-end action-cell">
                            <a asp-action="Details" asp-route-id="@item.VaccinationId" class="btn btn-sm btn-outline-secondary">Details</a>
                            <a asp-action="Edit" asp-route-id="@item.VaccinationId" class="btn btn-sm btn-outline-primary">Edit</a>
                            <a asp-action="Delete" asp-route-id="@item.VaccinationId" class="btn btn-sm btn-outline-danger">Delete</a>
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
</div>
