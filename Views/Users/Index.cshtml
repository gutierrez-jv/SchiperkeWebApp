@model IEnumerable<User>

@{
    ViewData["Title"] = "Users";
}

<div class="page-header">
    <div>
        <div class="page-kicker">Access Control</div>
        <h1>Users</h1>
        <p class="page-subtitle">Active admin and staff accounts for clinic record access.</p>
    </div>
    <div class="page-actions">
        <a asp-action="Create" class="btn btn-primary">Add User</a>
    </div>
</div>

<div class="table-shell">
    <div class="table-responsive">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Full Name</th>
                    <th>Username</th>
                    <th>Role</th>
                    <th>Created</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="5" class="empty-state">No active users found.</td>
                </tr>
            }
            else
            {
                @foreach (var item in Model)
                {
                    <tr>
                        <td><strong>@item.FullName</strong></td>
                        <td>@item.Username</td>
                        <td><span class="status-badge">@item.Role</span></td>
                        <td>@item.CreatedAt.ToString("yyyy-MM-dd")</td>
                        <td class="text-end action-cell">
                            <a asp-action="Details" asp-route-id="@item.UserId" class="btn btn-sm btn-outline-secondary">Details</a>
                            <a asp-action="Edit" asp-route-id="@item.UserId" class="btn btn-sm btn-outline-primary">Edit</a>
                            <a asp-action="Delete" asp-route-id="@item.UserId" class="btn btn-sm btn-outline-danger">Delete</a>
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
</div>
