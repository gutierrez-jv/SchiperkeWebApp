@model AppointmentFormViewModel

@{
    var hasPatientNumber = !string.IsNullOrWhiteSpace(Model.PatientNoInput);
    var hasRegisteredPatient = Model.PetId.HasValue;
    var showPatientNumberInput = Model.IsExistingPatient || hasPatientNumber || hasRegisteredPatient;
    var lockPatientNumber = hasPatientNumber || hasRegisteredPatient;
}

<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

<div data-staff-appointment-form>
<input asp-for="CreatedByUserId" type="hidden" />
<input asp-for="PetId" type="hidden" />
<input asp-for="AppointmentCode" type="hidden" />
<input asp-for="CancelledBy" type="hidden" />
<input asp-for="CancelledAt" type="hidden" />

@if (!string.IsNullOrWhiteSpace(Model.AppointmentCode))
{
    <div class="soft-delete-note mb-3">
        Appointment reference: <strong>@Model.AppointmentCode</strong>
    </div>
}

<section class="form-section">
    <h2 class="h5">Previous Visit</h2>
    <div class="form-check form-switch">
        <input asp-for="IsExistingPatient" class="form-check-input" role="switch" />
        <label asp-for="IsExistingPatient" class="form-check-label"></label>
    </div>
    <p class="form-hint">Use the patient number only if the pet already has a clinic record.</p>
    <div class="row g-3" data-staff-patient-number-section hidden="@(!showPatientNumberInput)">
        <div class="col-md-6">
            <label asp-for="PatientNoInput" class="form-label"></label>
            @if (lockPatientNumber)
            {
                <input asp-for="PatientNoInput" class="form-control patient-number-disabled" readonly />
                <span class="form-hint">Patient number is pulled from the registered patient record and cannot be changed here.</span>
            }
            else
            {
                <input asp-for="PatientNoInput" class="form-control" autocomplete="off" />
            }
            <span asp-validation-for="PatientNoInput" class="text-danger"></span>
        </div>
    </div>
    <div class="locked-context-card" data-staff-new-patient-note hidden="@showPatientNumberInput">
        <span>New patient appointment</span>
        <strong>Patient number will be generated after registration.</strong>
        <small>Use Register on the appointment list/details page after the clinic confirms the visit.</small>
    </div>
</section>

<section class="form-section" data-staff-pet-details-section hidden="@showPatientNumberInput">
    <h2 class="h5">Pet Details</h2>
    <div class="row g-3">
        <div class="col-md-6">
            <label asp-for="PetName" class="form-label"></label>
            <input asp-for="PetName" class="form-control" autocomplete="off" data-staff-pet-detail-field />
            <span asp-validation-for="PetName" class="text-danger"></span>
        </div>
        <div class="col-md-3">
            <label asp-for="Species" class="form-label"></label>
            <input asp-for="Species" class="form-control" data-staff-pet-detail-field />
            <span asp-validation-for="Species" class="text-danger"></span>
        </div>
        <div class="col-md-3">
            <label asp-for="Sex" class="form-label"></label>
            <select asp-for="Sex" asp-items="Model.SexOptions" class="form-select" data-staff-pet-detail-field>
                <option value="">Select sex</option>
            </select>
            <span asp-validation-for="Sex" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="Breed" class="form-label"></label>
            <input asp-for="Breed" class="form-control" autocomplete="off" data-staff-pet-detail-field />
            <span asp-validation-for="Breed" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="Color" class="form-label"></label>
            <input asp-for="Color" class="form-control" autocomplete="off" data-staff-pet-detail-field />
            <span asp-validation-for="Color" class="text-danger"></span>
        </div>
    </div>
</section>

<section class="form-section">
    <h2 class="h5">Schedule</h2>
    <div class="row g-3">
        <div class="col-md-3">
            <label asp-for="AppointmentDate" class="form-label"></label>
            <input asp-for="AppointmentDate" type="date" class="form-control" />
            <span asp-validation-for="AppointmentDate" class="text-danger"></span>
        </div>
        <div class="col-md-3">
            <label asp-for="AppointmentTime" class="form-label"></label>
            <select id="AppointmentTime" name="AppointmentTime" class="form-select">
                <option value="">Select time</option>
                @foreach (var option in Model.TimeOptions)
                {
                    if (option.Selected)
                    {
                        <option value="@option.Value" selected>@option.Text</option>
                    }
                    else
                    {
                        <option value="@option.Value">@option.Text</option>
                    }
                }
            </select>
            <span asp-validation-for="AppointmentTime" class="text-danger"></span>
        </div>
        <div class="col-md-3">
            <label asp-for="ServiceType" class="form-label"></label>
            <select asp-for="ServiceType" asp-items="Model.ServiceTypeOptions" class="form-select">
                <option value="">Select service type</option>
            </select>
            <span asp-validation-for="ServiceType" class="text-danger"></span>
        </div>
        <div class="col-md-3">
            <label asp-for="Status" class="form-label"></label>
            <select asp-for="Status" asp-items="Model.StatusOptions" class="form-select" id="Status">
                <option value="">Select status</option>
            </select>
            <span asp-validation-for="Status" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="ReasonForVisit" class="form-label"></label>
            <input asp-for="ReasonForVisit" class="form-control" />
            <span asp-validation-for="ReasonForVisit" class="text-danger"></span>
        </div>
        <div class="col-12">
            <label asp-for="Remarks" class="form-label"></label>
            <textarea asp-for="Remarks" class="form-control" rows="4"></textarea>
            <span asp-validation-for="Remarks" class="text-danger"></span>
        </div>
    </div>
</section>
</div>

<section class="form-section" id="cancellationSection">
    <h2 class="h5">Cancellation</h2>
    <p class="form-hint">Add the clinic reason shown when the client checks a cancelled appointment.</p>
    <div class="row g-3">
        <div class="col-12">
            <label asp-for="CancellationReason" class="form-label"></label>
            <textarea asp-for="CancellationReason" class="form-control" rows="3" maxlength="500"></textarea>
            <span asp-validation-for="CancellationReason" class="text-danger"></span>
        </div>
    </div>
</section>
