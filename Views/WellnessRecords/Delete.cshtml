@model WellnessRecord

@{
    ViewData["Title"] = "Delete Wellness Record";
}

<h1>Delete Wellness Record</h1>
<div class="soft-delete-note">
    Are you sure you want to delete this wellness record? This record will not be permanently removed and will only be hidden from normal lists.
</div>

<dl class="row">
    <dt class="col-sm-3">Pet</dt>
    <dd class="col-sm-9">@Model.Pet.PatientNo - @Model.Pet.PetName</dd>
    <dt class="col-sm-3">Wellness Type</dt>
    <dd class="col-sm-9">@Model.WellnessType</dd>
    <dt class="col-sm-3">Product / Medication</dt>
    <dd class="col-sm-9">@Model.ProductOrMedication</dd>
</dl>

<form asp-action="Delete" method="post" data-paws-confirm="Delete this wellness record? It will be hidden from normal lists but kept in the database.">
    <input type="hidden" asp-for="WellnessId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
</form>
